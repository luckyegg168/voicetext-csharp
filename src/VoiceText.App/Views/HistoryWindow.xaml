<!-- src/VoiceText.App/Views/HistoryWindow.xaml -->
<Window x:Class="VoiceText.App.Views.HistoryWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="歷史記錄" Height="520" Width="600" xml:lang="zh-TW"
        Background="{StaticResource BackgroundPrimaryBrush}"
        WindowStyle="None" AllowsTransparency="True"
        ResizeMode="CanResize">

  <Border CornerRadius="12" Background="{StaticResource BackgroundPrimaryBrush}"
          BorderBrush="{StaticResource SeparatorBrush}" BorderThickness="0.5">
    <Grid>
      <Grid.RowDefinitions>
        <RowDefinition Height="44"/>
        <RowDefinition Height="50"/>
        <RowDefinition Height="*"/>
        <RowDefinition Height="52"/>
      </Grid.RowDefinitions>

      <!-- Title bar -->
      <Grid Grid.Row="0" Background="Transparent" MouseLeftButtonDown="TitleBar_MouseLeftButtonDown">
        <TextBlock Text="歷史記錄" Style="{StaticResource Headline}"
                   HorizontalAlignment="Center" VerticalAlignment="Center"/>
        <Button Content="✕" HorizontalAlignment="Right" Margin="0,0,8,0"
                Style="{StaticResource AppleButton}" Background="Transparent"
                Foreground="{StaticResource SystemGrayBrush}"
                Click="CloseButton_Click"/>
      </Grid>

      <!-- Search bar -->
      <Grid Grid.Row="1" Margin="16,8">
        <TextBox Text="{Binding SearchQuery, UpdateSourceTrigger=PropertyChanged}"
                 Style="{StaticResource AppleTextBox}"
                 x:Name="SearchBox"/>
        <Button Content="🔍" HorizontalAlignment="Right" Margin="0,0,4,0"
                Style="{StaticResource AppleButton}" Background="Transparent"
                Foreground="{StaticResource SystemGrayBrush}"
                Command="{Binding SearchCommand}"/>
      </Grid>

      <!-- History list -->
      <ListBox Grid.Row="2" ItemsSource="{Binding Entries}"
               SelectedItem="{Binding SelectedEntry}"
               Margin="16,0" BorderThickness="0"
               Background="Transparent">
        <ListBox.ItemTemplate>
          <DataTemplate>
            <Border Style="{StaticResource AppleCard}" Margin="0,4" Padding="12">
              <StackPanel>
                <TextBlock Text="{Binding CreatedAt, StringFormat='{}{0:yyyy年MM月dd日 HH:mm}'}"
                           Style="{StaticResource Caption}"/>
                <TextBlock Text="{Binding RawText}" TextTrimming="CharacterEllipsis"
                           MaxHeight="40" FontFamily="{StaticResource AppleFont}" FontSize="14"
                           Margin="0,4,0,0"/>
                <TextBlock Text="{Binding PolishedText}" TextTrimming="CharacterEllipsis"
                           MaxHeight="40" FontFamily="{StaticResource AppleFont}" FontSize="13"
                           Foreground="{StaticResource LabelSecondaryBrush}"/>
              </StackPanel>
            </Border>
          </DataTemplate>
        </ListBox.ItemTemplate>
      </ListBox>

      <!-- Footer -->
      <Border Grid.Row="3" BorderBrush="{StaticResource SeparatorBrush}" BorderThickness="0,0.5,0,0"
              Background="{StaticResource BackgroundSecondaryBrush}">
        <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="16,0">
          <Button Content="📋 複製" Style="{StaticResource AppleButton}" Margin="0,0,8,0"
                  Background="{StaticResource BackgroundTertiaryBrush}"
                  Foreground="{StaticResource LabelPrimaryBrush}"
                  Command="{Binding CopySelectedToClipboardCommand}"/>
          <Button Content="🗑 刪除" Style="{StaticResource AppleButton}"
                  Background="{StaticResource SystemRedBrush}"
                  Command="{Binding DeleteSelectedCommand}"/>
        </StackPanel>
      </Border>
    </Grid>
  </Border>
</Window>
