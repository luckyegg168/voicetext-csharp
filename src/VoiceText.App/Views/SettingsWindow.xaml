<!-- src/VoiceText.App/Views/SettingsWindow.xaml -->
<Window x:Class="VoiceText.App.Views.SettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="設定" Height="600" Width="480" xml:lang="zh-TW"
        Background="{StaticResource BackgroundPrimaryBrush}"
        WindowStyle="None" AllowsTransparency="True"
        ResizeMode="NoResize">

  <Border CornerRadius="12" Background="{StaticResource BackgroundPrimaryBrush}"
          BorderBrush="{StaticResource SeparatorBrush}" BorderThickness="0.5">
    <Grid>
      <Grid.RowDefinitions>
        <RowDefinition Height="44"/>
        <RowDefinition Height="*"/>
        <RowDefinition Height="52"/>
      </Grid.RowDefinitions>

      <!-- Title bar -->
      <Grid Grid.Row="0" MouseLeftButtonDown="TitleBar_MouseLeftButtonDown">
        <TextBlock Text="設定" Style="{StaticResource Headline}"
                   HorizontalAlignment="Center" VerticalAlignment="Center"/>
        <Button Content="✕" HorizontalAlignment="Right" Margin="0,0,8,0"
                Style="{StaticResource AppleButton}" Background="Transparent"
                Foreground="{StaticResource SystemGrayBrush}"
                Click="CloseButton_Click"/>
      </Grid>

      <!-- Settings content -->
      <ScrollViewer Grid.Row="1" Padding="16,8">
        <StackPanel>

          <!-- ASR Section -->
          <TextBlock Text="語音識別 (ASR)" Style="{StaticResource Headline}" Margin="0,8,0,8"/>
          <Border Style="{StaticResource AppleCard}" Margin="0,0,0,12">
            <StackPanel>
              <Grid Margin="0,4">
                <Grid.ColumnDefinitions><ColumnDefinition Width="140"/><ColumnDefinition/></Grid.ColumnDefinitions>
                <TextBlock Text="模型" VerticalAlignment="Center" FontFamily="{StaticResource AppleFont}"/>
                <ComboBox Grid.Column="1" ItemsSource="{Binding AsrModels}"
                          SelectedValue="{Binding AsrModelId}" Style="{StaticResource AppleComboBox}"/>
              </Grid>
              <Grid Margin="0,4">
                <Grid.ColumnDefinitions><ColumnDefinition Width="140"/><ColumnDefinition/></Grid.ColumnDefinitions>
                <TextBlock Text="伺服器主機" VerticalAlignment="Center" FontFamily="{StaticResource AppleFont}"/>
                <TextBox Grid.Column="1" Text="{Binding AsrServerHost}" Style="{StaticResource AppleTextBox}"/>
              </Grid>
              <Grid Margin="0,4">
                <Grid.ColumnDefinitions><ColumnDefinition Width="140"/><ColumnDefinition/></Grid.ColumnDefinitions>
                <TextBlock Text="伺服器埠" VerticalAlignment="Center" FontFamily="{StaticResource AppleFont}"/>
                <TextBox Grid.Column="1" Text="{Binding AsrServerPort}" Style="{StaticResource AppleTextBox}"/>
              </Grid>
            </StackPanel>
          </Border>

          <!-- LLM Section -->
          <TextBlock Text="語言模型 (LLM)" Style="{StaticResource Headline}" Margin="0,8,0,8"/>
          <Border Style="{StaticResource AppleCard}" Margin="0,0,0,12">
            <StackPanel>
              <Grid Margin="0,4">
                <Grid.ColumnDefinitions><ColumnDefinition Width="140"/><ColumnDefinition/></Grid.ColumnDefinitions>
                <TextBlock Text="後端" VerticalAlignment="Center" FontFamily="{StaticResource AppleFont}"/>
                <ComboBox Grid.Column="1" ItemsSource="{Binding LlmBackends}"
                          SelectedValue="{Binding LlmBackend}" Style="{StaticResource AppleComboBox}"/>
              </Grid>
              <Grid Margin="0,4">
                <Grid.ColumnDefinitions><ColumnDefinition Width="140"/><ColumnDefinition/></Grid.ColumnDefinitions>
                <TextBlock Text="模型名稱" VerticalAlignment="Center" FontFamily="{StaticResource AppleFont}"/>
                <TextBox Grid.Column="1" Text="{Binding LlmModelName}" Style="{StaticResource AppleTextBox}"/>
              </Grid>
              <Grid Margin="0,4">
                <Grid.ColumnDefinitions><ColumnDefinition Width="140"/><ColumnDefinition/></Grid.ColumnDefinitions>
                <TextBlock Text="潤稿風格" VerticalAlignment="Center" FontFamily="{StaticResource AppleFont}"/>
                <ComboBox Grid.Column="1" ItemsSource="{Binding PolishStyles}"
                          SelectedValue="{Binding PolishPromptStyle}" Style="{StaticResource AppleComboBox}"/>
              </Grid>
              <Grid Margin="0,4">
                <Grid.ColumnDefinitions><ColumnDefinition Width="140"/><ColumnDefinition/></Grid.ColumnDefinitions>
                <TextBlock Text="Ollama URL" VerticalAlignment="Center" FontFamily="{StaticResource AppleFont}"/>
                <TextBox Grid.Column="1" Text="{Binding OllamaBaseUrl}" Style="{StaticResource AppleTextBox}"/>
              </Grid>
            </StackPanel>
          </Border>

          <!-- Audio Section -->
          <TextBlock Text="音頻" Style="{StaticResource Headline}" Margin="0,8,0,8"/>
          <Border Style="{StaticResource AppleCard}" Margin="0,0,0,12">
            <StackPanel>
              <Grid Margin="0,4">
                <Grid.ColumnDefinitions><ColumnDefinition Width="140"/><ColumnDefinition/></Grid.ColumnDefinitions>
                <TextBlock Text="麥克風" VerticalAlignment="Center" FontFamily="{StaticResource AppleFont}"/>
                <ComboBox Grid.Column="1" ItemsSource="{Binding Microphones}"
                          SelectedValue="{Binding SelectedMicrophoneId}"
                          DisplayMemberPath="Name" SelectedValuePath="Id"
                          Style="{StaticResource AppleComboBox}"/>
              </Grid>
              <Grid Margin="0,4">
                <Grid.ColumnDefinitions><ColumnDefinition Width="140"/><ColumnDefinition/></Grid.ColumnDefinitions>
                <TextBlock Text="靜默逾時 (ms)" VerticalAlignment="Center" FontFamily="{StaticResource AppleFont}"/>
                <TextBox Grid.Column="1" Text="{Binding VadSilenceTimeoutMs}" Style="{StaticResource AppleTextBox}"/>
              </Grid>
            </StackPanel>
          </Border>

          <!-- General Section -->
          <TextBlock Text="一般" Style="{StaticResource Headline}" Margin="0,8,0,8"/>
          <Border Style="{StaticResource AppleCard}" Margin="0,0,0,12">
            <StackPanel>
              <CheckBox Content="自動複製到剪貼簿" IsChecked="{Binding AutoCopyToClipboard}"
                        FontFamily="{StaticResource AppleFont}" Margin="0,4"/>
              <Grid Margin="0,4">
                <Grid.ColumnDefinitions><ColumnDefinition Width="140"/><ColumnDefinition/></Grid.ColumnDefinitions>
                <TextBlock Text="全局熱鍵" VerticalAlignment="Center" FontFamily="{StaticResource AppleFont}"/>
                <TextBox Grid.Column="1" Text="{Binding GlobalHotkey}" Style="{StaticResource AppleTextBox}"/>
              </Grid>
            </StackPanel>
          </Border>

        </StackPanel>
      </ScrollViewer>

      <!-- Footer buttons -->
      <Border Grid.Row="2" BorderBrush="{StaticResource SeparatorBrush}" BorderThickness="0,0.5,0,0"
              Background="{StaticResource BackgroundSecondaryBrush}">
        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right"
                    VerticalAlignment="Center" Margin="16,0">
          <Button Content="取消" Style="{StaticResource AppleButton}" Margin="0,0,8,0"
                  Background="{StaticResource BackgroundTertiaryBrush}"
                  Foreground="{StaticResource LabelPrimaryBrush}"
                  Click="CloseButton_Click"/>
          <Button Content="儲存" Style="{StaticResource AppleButton}"
                  Command="{Binding SaveCommand}"
                  Click="SaveAndClose_Click"/>
        </StackPanel>
      </Border>
    </Grid>
  </Border>
</Window>
